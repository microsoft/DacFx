<?xml version="1.0" encoding="utf-8"?>
<!-- Test project for SQLCLR assembly compilation under the .NET SDK build path. See https://github.com/microsoft/DacFx/issues/785 -->
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="1.0.0-test" />
  <PropertyGroup>
    <Name>Project</Name>
    <DSP>Microsoft.Data.Tools.Schema.Sql.Sql150DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
    <ProjectGuid>{00000000-0000-0000-0000-000000000000}</ProjectGuid>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="StoredProcedures.cs" />
  </ItemGroup>
</Project>
